#!/usr/bin/env bash

TITLE_MAX_LEN=25
PLAYING_ICON="󰐊"
PAUSED_ICON="󰏤"

handle_cmus() {
	local data="$1"
	local icon="" dur=0 pos=0 title="" rem=4
	local line
	while IFS= read -r line; do
		case "$line" in
			status\ *)
				case "${line#status }" in
					playing) icon="$PLAYING_ICON"; ((--rem)) || break ;;
					paused) icon="$PAUSED_ICON"; ((--rem)) || break ;;
					stopped) exit 0 ;;
				esac
				;;
			duration\ *)
				dur=${line#duration }
				((--rem)) || break
				;;
			position\ *)
				pos=${line#position }
				((--rem)) || break
				;;
			tag\ title\ *)
				title=${line#tag title }
				((--rem)) || break
				;;
		esac
	done <<< "$data"

	[ ${#title} -gt $TITLE_MAX_LEN ] && title="${title::TITLE_MAX_LEN}..."

	printf "%s %02d:%02d/%02d:%02d %s" \
		"$icon" \
		$((pos / 60)) $((pos % 60)) $((dur / 60)) $((dur % 60)) \
		"$title"
}

cmus_data="$(cmus-remote -Q 2> /dev/null)" && \
	{ handle_cmus "$cmus_data"; exit 0; }

pc_out="$(playerctl metadata --format '{{status}}|{{title}}' 2> /dev/null)"
pc_title="${pc_out#*|}"
case "${pc_out%%|*}" in
	Playing) icon="$PLAYING_ICON" ;;
	Paused) icon="$PAUSED_ICON" ;;
	*) icon="" ;;
esac

[ ${#pc_title} -gt $TITLE_MAX_LEN ] && pc_title="${pc_title:0:TITLE_MAX_LEN}..."
printf "%s %s" \
	"$icon" "$pc_title"
