#!/usr/bin/env bash

step="0.05"

case "$1" in
	-) wpctl set-volume @DEFAULT_SINK@ $step- 2> /dev/null ;;
	+) wpctl set-volume @DEFAULT_SINK@ $step+ 2> /dev/null ;;
	mute) wpctl set-mute @DEFAULT_SINK@ toggle 2> /dev/null ;;
	-h)
		echo "Usage: ${0##*/} [-] [+] [mute]
  -      decrease volume by $step
  +      increase volume by $step
  mute   toggle mute"
		exit 0
		;;
	*) exit 2 ;;
esac
